{{ if eq .chezmoi.os "windows" -}}
# Configure Visual Studio Code to use an XDG-style configuration directory.
#
# Sets the user environment variable:
#   VSCODE_APPDATA=%USERPROFILE%\.config
#
# This script is intended to run once via chezmoi.

$name = 'VSCODE_APPDATA'
$value = "$env:USERPROFILE\.config"

$current = [Environment]::GetEnvironmentVariable($name, 'User')

if ($current -eq $value) {
    Write-Host "VSCODE_APPDATA is already configured."
    return
}

[Environment]::SetEnvironmentVariable($name, $value, 'User')

Write-Host "Configured user environment variable:"
Write-Host "  $name = $value"

Write-Host ""
Write-Host "Restart Visual Studio Code (and any open terminals) for the change to take effect."
{{- end }}
