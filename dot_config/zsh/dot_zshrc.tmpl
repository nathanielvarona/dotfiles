# =========================================================
# ZSH Configuration (Managed by chezmoi)
# Cross-platform: macOS / Linux / WSL
# All OS branching handled at template time (ZERO runtime branching)
# =========================================================

# ---------------------------------------------------------
# Core Environment
# ---------------------------------------------------------

export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export EDITOR="nvim"
export NVIM_APPNAME="lazyvim"

# XDG Base Directory Specification
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"


{{ if eq .chezmoi.os "linux" }}
export GIT_CONFIG_GLOBAL="${XDG_CONFIG_HOME}/git/config"
export VSCODE_APPDATA="${XDG_CONFIG_HOME}"
export GNUPGHOME="${XDG_CONFIG_HOME}/gnupg"
{{ end }}

# Load secrets if present
[[ -f ~/.secrets ]] && source ~/.secrets

# ---------------------------------------------------------
# Platform-Specific Paths (Resolved by chezmoi)
# ---------------------------------------------------------

{{ if eq .chezmoi.os "darwin" }}
# macOS (Homebrew - Intel default)
export HOMEBREW_PREFIX="/usr/local"
{{ else }}
# Linux / WSL (Linuxbrew default)
export HOMEBREW_PREFIX="/home/linuxbrew/.linuxbrew"
{{ end }}

# Initialize Homebrew (if installed)
if [ -x "$HOMEBREW_PREFIX/bin/brew" ]; then
  eval "$($HOMEBREW_PREFIX/bin/brew shellenv)"
fi

# typeset -g POWERLEVEL9K_INSTANT_PROMPT=quiet
# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
# if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
#   source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
# fi

# ---------------------------------------------------------
# Prompt (Oh My Posh)
# ---------------------------------------------------------

if [ "$TERM_PROGRAM" != "Apple_Terminal" ]; then
  export POSH_CONFIG="$XDG_CONFIG_HOME/oh-my-posh/zen.omp.toml"
  eval "$(oh-my-posh init zsh)"
fi

# ---------------------------------------------------------
# Zinit Plugin Manager
# ---------------------------------------------------------

# Path differs per platform (templated)
{{ if eq .chezmoi.os "darwin" }}
ZINIT_HOME="$HOMEBREW_PREFIX/opt/zinit"
{{ else }}
ZINIT_HOME="$HOMEBREW_PREFIX/opt/zinit"
{{ end }}

# Load Zinit
if [ -f "$ZINIT_HOME/zinit.zsh" ]; then
  source "$ZINIT_HOME/zinit.zsh"
fi

# Ensure completion cache exists
ZSH_CACHE_DIR="${XDG_CACHE_HOME}/zsh"
[[ ! -e $ZSH_CACHE_DIR/completions ]] && mkdir -p $ZSH_CACHE_DIR/completions

# Add in Powerlevel10k
# zinit ice depth=1
# zinit light romkatv/powerlevel10k

# To customize prompt, run `p10k configure` or edit $XDG_CONFIG_HOME/powerlevel10k/p10k.zsh.
# [[ ! -f $XDG_CONFIG_HOME/powerlevel10k/p10k.zsh ]] || source $XDG_CONFIG_HOME/powerlevel10k/p10k.zsh

# ---------------------------------------------------------
# Plugins
# ---------------------------------------------------------

zinit light zsh-users/zsh-history-substring-search
zinit light zsh-users/zsh-syntax-highlighting
zinit light zsh-users/zsh-autosuggestions
zinit light zsh-users/zsh-completions

# OMZ snippets
zinit snippet OMZ::plugins/git
zinit snippet OMZ::plugins/extract
zinit snippet OMZ::plugins/common-aliases
zinit snippet OMZ::plugins/vi-mode

{{ if eq .chezmoi.os "darwin" }}
# API documentation browser and code snippet manager
zinit snippet OMZ::plugins/dash
{{ end }}

# vi-mode plugin settings
VI_MODE_RESET_PROMPT_ON_MODE_CHANGE=true
VI_MODE_SET_CURSOR=true

# ---------------------------------------------------------
# CLI Tools Initialization
# ---------------------------------------------------------

# fzf
source <(fzf --zsh)

# atuin (history DB)
export ATUIN_NOBIND="true"
eval "$(atuin init zsh)"
bindkey '^Y' atuin-search
# bind to the up key, which depends on terminal mode
# bindkey '\eOA' atuin-up-search
# bindkey '\eOB' atuin-up-search

# fzf is a general-purpose command-line fuzzy finder.
# https://github.com/junegunn/fzf
function init_fzfrc() {
  [[ ! -f $XDG_CONFIG_HOME/fzf/fzfrc.zsh ]] || source $XDG_CONFIG_HOME/fzf/fzfrc.zsh
}
# Load FZF Custom Options
init_fzfrc

# Replace zsh's default completion selection menu with fzf!
# https://github.com/Aloxaf/fzf-tab
zinit light Aloxaf/fzf-tab

# A CLI interface to git that relies heavily on fzf
# https://github.com/bigH/git-fuzzy
# Usage: "[git-fuzzy | git fuzzy] <GIT_SUBCOMMAND>"
zinit ice as"program" pick"bin/git-fuzzy"
zinit light bigH/git-fuzzy

# Utility tool for using git interactively.
# https://github.com/wfxr/forgit
# Usage: "[git-forgit | git forgit] <GIT_SUBCOMMAND>"
zinit ice as"program" pick"bin/git-forgit"
zinit load wfxr/forgit

# Shell extension to navigate your filesystem faster
source <(zoxide init --cmd cd zsh)

# Jump around (same with zoxide) with fzf
zinit load agkozak/zsh-z

# Last Command Correction
eval "$(thefuck --alias wtf)"

# ---------------------------------------------------------
# History Configuration
# ---------------------------------------------------------

export HISTFILE=~/.zsh_history
export HISTSIZE=1000000000
export HISTFILESIZE=1000000000
export HISTTIMEFORMAT="[%F %T] "

setopt INC_APPEND_HISTORY
setopt EXTENDED_HISTORY
setopt HIST_FIND_NO_DUPS
setopt HIST_IGNORE_ALL_DUPS

# ---------------------------------------------------------
# Plugin Configuration
# ---------------------------------------------------------

# History substring search
bindkey '\eOA' history-substring-search-up
bindkey '\eOB' history-substring-search-down
export HISTORY_SUBSTRING_SEARCH_ENSURE_UNIQUE=1
export HISTORY_SUBSTRING_SEARCH_HIGHLIGHT_FOUND=0
export HISTORY_SUBSTRING_SEARCH_HIGHLIGHT_NOT_FOUND=0

# Autosuggestions
export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=242"

# Syntax highlighting
export ZSH_HIGHLIGHT_HIGHLIGHTERS=(
  main
  brackets
  pattern
  # cursor
)

export ZSH_HIGHLIGHT_STYLES['unknown-token']=fg=red
export ZSH_HIGHLIGHT_STYLES['suffix-alias']=fg=green,underline
export ZSH_HIGHLIGHT_STYLES[precommand]=fg=green,underline
export ZSH_HIGHLIGHT_STYLES[arg0]=fg=green

# Zsh Vi Mode
# zinit ice depth=1
# zinit light jeffreytse/zsh-vi-mode
# Fix zsh-history-substring-search behaviour
# zvm_after_init_commands+=(
#   init_fzfrc
#   "bindkey '\eOA' history-substring-search-up"
#   "bindkey '\eOB' history-substring-search-down"
# )
# export ZVM_VI_EDITOR=vim
# export ZVM_SYSTEM_CLIPBOARD_ENABLED=true

# GNU Bins
# NOTE: Some were internally loaded in the $PATH if without conflicts
#
# export PATH="/usr/local/opt/inetutils/libexec/gnubin:$PATH"
# export PATH="/usr/local/opt/coreutils/libexec/gnubin:$PATH"
# export PATH="/usr/local/opt/gnu-sed/libexec/gnubin:$PATH"
# export PATH="/usr/local/opt/gnu-getopt/bin:$PATH"

{{ if eq .chezmoi.os "darwin" }}
