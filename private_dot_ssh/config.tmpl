# -*-mode:ssh-config-*- vim:ft=sshconfig

# =============================================================================
# ~/.ssh/config
# OpenSSH Client Configuration (chezmoi managed)
#
# Design Goals:
# - Cross-platform (macOS, Linux, WSL, Windows)
# - Secure defaults
# - Minimal runtime surprises
# - Fast connection reuse (non-Windows)
#
# Docs:
# https://www.ssh.com/ssh/config
# =============================================================================

# -----------------------------------------------------------------------------
# Compatibility
# -----------------------------------------------------------------------------

# Ignore unknown options (prevents errors across OS/OpenSSH versions)
IgnoreUnknown AddKeysToAgent,UseKeychain,IdentityAgent

# -----------------------------------------------------------------------------
# Global Defaults
# -----------------------------------------------------------------------------

Host *
    # -------------------------------------------------------------------------
    # Connection Performance (disabled on Windows)
    # -------------------------------------------------------------------------
    {{- if ne .chezmoi.os "windows" }}
    # Reuse SSH connections (multiplexing)
    ControlMaster auto
    ControlPath ~/.ssh/controlmasters/%r@%h:%p
    ControlPersist 10m
    {{- end }}

    # -------------------------------------------------------------------------
    # Authentication
    # -------------------------------------------------------------------------
    AddKeysToAgent yes

    {{- if eq .chezmoi.os "darwin" }}
    # macOS Keychain integration (Apple OpenSSH patch)
    UseKeychain yes
    {{- end }}

    # Prefer modern key types
    PubkeyAuthentication yes
    IdentitiesOnly yes

    # -------------------------------------------------------------------------
    # Security Hardening
    # -------------------------------------------------------------------------
    # Disable agent forwarding by default (override per-host if needed)
    ForwardAgent no

    # Enforce strict host key checking (safer default)
    StrictHostKeyChecking ask

    # Hash known hosts file (privacy)
    HashKnownHosts yes

    # Disable password auth fallback (optional but recommended)
    PasswordAuthentication yes

    # -------------------------------------------------------------------------
    # Connection Stability
    # -------------------------------------------------------------------------
    ServerAliveInterval 300
    ServerAliveCountMax 6

    # -------------------------------------------------------------------------
    # Terminal Compatibility
    # -------------------------------------------------------------------------
    # Ensures compatibility with modern terminals (e.g., Ghostty, Kitty)
    SetEnv TERM=xterm-256color

    # -------------------------------------------------------------------------
    # Logging (useful for debugging)
    # -------------------------------------------------------------------------
    LogLevel ERROR


# -----------------------------------------------------------------------------
# Platform-Specific Overrides
# -----------------------------------------------------------------------------

{{- if eq .chezmoi.os "windows" }}

# Windows OpenSSH quirks:
# - No ControlMaster support
# - Different agent handling

Host *
    # Use Windows SSH agent if available
    IdentityAgent \\.\pipe\openssh-ssh-agent

{{- end }}


# -----------------------------------------------------------------------------
# Optional: GitHub (example)
# -----------------------------------------------------------------------------
# Host github.com
#     HostName github.com
#     User git
#     IdentityFile ~/.ssh/id_ed25519
#     IdentitiesOnly yes
