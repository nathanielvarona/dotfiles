{{- /* .chezmoitemplates/is_native */ -}}
{{- $isNative := false -}}
{{- if eq .chezmoi.os "darwin" -}}
  {{- $isNative = true -}}
{{- else if eq .chezmoi.os "linux" -}}
  {{- if not (.chezmoi.kernel.osrelease | lower | contains "microsoft") -}}
    {{- $isNative = true -}}
  {{- end -}}
{{- end -}}
{{- $isNative -}}
