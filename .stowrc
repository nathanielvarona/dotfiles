# .stowrc
#
# GNU Stow configuration file
# https://www.gnu.org/software/stow/
#
# This file defines default options used when running `stow` inside
# this dotfiles repository.
#
# Purpose
# - Sets the default target directory for symlinks.
# - Excludes repository metadata, documentation, and development files
#   that should never be symlinked into the home directory.
#
# Reference
# - GNU Stow Manual: https://www.gnu.org/software/stow/manual/stow.html

--target=~

# Ignore files and directories not meant to be stowed

# Ignore metadata and project files
--ignore=^README.md$
--ignore=^LICENSE$
--ignore=^Justfile$
--ignore=^.config/git/dist.gitconfig$

# Ignore editor/system files
--ignore=^\.DS_Store$
--ignore=^\.vscode$
--ignore=^\.develop$

# Ignore repository configs
--ignore=^\.editorconfig$
--ignore=^\.gitignore$
--ignore=^\.markdownlint-cli2.yaml$
--ignore=^\.stowrc$
--ignore=^\.taplo.toml$
--ignore=^\.tmuxp.yaml$

# Ignore documentation and assets
--ignore=^docs$
--ignore=^external$
--ignore=^pkgs$

