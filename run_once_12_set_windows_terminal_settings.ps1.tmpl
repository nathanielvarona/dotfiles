{{ if eq .chezmoi.os "windows" -}}
# Ensure Windows Terminal is installed and apply the managed settings patch.

Write-Host ""
Write-Host "Windows Terminal"

winget install --id Microsoft.WindowsTerminal `
  --accept-package-agreements `
  --accept-source-agreements

if ($LASTEXITCODE -ne 0) {
  winget upgrade --id Microsoft.WindowsTerminal `
    --accept-package-agreements `
    --accept-source-agreements
}

$settingsPath = Join-Path `
  $env:LOCALAPPDATA `
  "Packages\Microsoft.WindowsTerminal_8wekyb3d8bbwe\LocalState\settings.json"

if (-not (Test-Path $settingsPath)) {
  Write-Host "settings.json not found."
  Write-Host ""
  exit 0
}

$patch = @'
{{ template "helpers/windows-terminal-patch.json.tmpl" . }}
'@ | ConvertFrom-Json

$settings = Get-Content -Raw -Path $settingsPath | ConvertFrom-Json

function Merge-Json {
  param(
    [Parameter(Mandatory = $true)]
    $Target,

    [Parameter(Mandatory = $true)]
    $Patch
  )

  foreach ($property in $Patch.PSObject.Properties) {
    $name = $property.Name
    $value = $property.Value

    if ($value -is [pscustomobject]) {
      if ($null -eq $Target.$name) {
        $Target | Add-Member `
          -MemberType NoteProperty `
          -Name $name `
          -Value ([pscustomobject]@{})
      }

      Merge-Json -Target $Target.$name -Patch $value
    }
    else {
      if ($Target.PSObject.Properties.Match($name).Count -eq 0) {
        $Target | Add-Member `
          -MemberType NoteProperty `
          -Name $name `
          -Value $value
      }
      else {
        $Target.$name = $value
      }
    }
  }
}

Merge-Json -Target $settings -Patch $patch

$settings |
  ConvertTo-Json -Depth 100 |
  Set-Content -Path $settingsPath -Encoding UTF8

Write-Host "Applied settings patch."
Write-Host ""
{{- end }}
