
{{ if eq .chezmoi.os "windows" -}}
# Ensure Windows Terminal is installed and up to date.

Write-Host ""
Write-Host "Windows Terminal"

winget install --id Microsoft.WindowsTerminal `
  --accept-package-agreements `
  --accept-source-agreements

if ($LASTEXITCODE -ne 0) {
  winget upgrade --id Microsoft.WindowsTerminal `
    --accept-package-agreements `
    --accept-source-agreements
}

# Locate settings.json
$settingsPath = Join-Path `
  $env:LOCALAPPDATA `
  "Packages\Microsoft.WindowsTerminal_8wekyb3d8bbwe\LocalState\settings.json"

if (-not (Test-Path $settingsPath)) {
  Write-Host "settings.json not found."
  Write-Host ""
  exit 0
}

$settings = Get-Content -Raw -Path $settingsPath | ConvertFrom-Json

# Ensure profiles exists
if ($null -eq $settings.profiles) {
  $settings | Add-Member `
    -MemberType NoteProperty `
    -Name profiles `
    -Value ([pscustomobject]@{})
}

# Ensure defaults exists
if ($null -eq $settings.profiles.defaults) {
  $settings.profiles | Add-Member `
    -MemberType NoteProperty `
    -Name defaults `
    -Value ([pscustomobject]@{})
}

# Ensure font exists
if ($null -eq $settings.profiles.defaults.font) {
  $settings.profiles.defaults | Add-Member `
    -MemberType NoteProperty `
    -Name font `
    -Value ([pscustomobject]@{})
}

$fontFace = "Cascadia Mono, Symbols Nerd Font Mono"

if ($settings.profiles.defaults.font.face -ne $fontFace) {
  $settings.profiles.defaults.font.face = $fontFace

  $settings |
    ConvertTo-Json -Depth 100 |
    Set-Content -Path $settingsPath -Encoding UTF8

  Write-Host "Updated font.face."
}
else {
  Write-Host "Already configured."
}

Write-Host "Done."
Write-Host ""
{{- end }}
